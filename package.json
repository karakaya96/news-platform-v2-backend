{
  "name": "news-platform-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute news-platform-db --local --file=./db/schema.sql",
    "db:seed": "wrangler d1 execute news-platform-db --local --file=./db/seed.sql",
    "db:init:remote": "wrangler d1 execute news-platform-db --remote --file=./db/schema.sql",
    "db:seed:remote": "wrangler d1 execute news-platform-db --remote --file=./db/seed.sql",
    "typegen": "wrangler types --env-interface CloudflareEnv env.d.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240614.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.60.0"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "jose": "^5.4.0",
    "zod": "^3.23.0"
  }
}
